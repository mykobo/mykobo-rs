      "severity": "critical"
    },
    "TRANSACTION_FUNDED_INFO": {
      "audience": "platform",
      "kind": "notification",
      "severity": "info"
    },
    "TRANSACTION_HELD_ALERT": {
      "audience": "platform",
      "kind": "notification",
      "severity": "warning"
    },
    "TRANSACTION_STATUS_UPDATE": {
      "kind": "domain",
      "notifies": [
        {
          "fires": [
            "TRANSACTION_FAILED_ALERT"
          ],
          "when": {
            "field": "status",
            "op": "eq",
            "value": "FAILED"
          }
        },
        {
          "fires": [
            "TRANSACTION_HELD_ALERT"
          ],
          "when": {
            "field": "status",
            "op": "eq",
            "value": "HELD"
          }
        },
        {
          "fires": [
            "CUSTOMER_FUNDS_RECEIVED",
            "TRANSACTION_FUNDED_INFO"
          ],
          "when": {
            "field": "status",
            "op": "eq",
            "value": "FUNDS_RECEIVED"
          }
        }
      ],
      "reason": null
    },
    "VERIFICATION_REQUESTED": {
      "kind": "domain",
      "notifies": [],
      "reason": "Today's verification email is derived in the notifications service (legacy CommandVerifyEmail path in app/message_handlers/kafka.py). Per-producer migration (Identity) will introduce an explicit CUSTOMER_VERIFICATION_REQUESTED notification variant."
    },
